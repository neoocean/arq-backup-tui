# Template for tests/integration/test_arqapp_sftp_compat.py.
#
# Copy to .env (NOT checked into git per .gitignore) and fill in
# with your real SFTP + Arq destination details.
#
#   cp .env.example .env
#   chmod 600 .env
#   # edit .env
#
# Then run the integration tests:
#
#   python -m unittest discover -s tests/integration -v

# --- SFTP server (where the Arq destination lives) -------------
ARQ_TEST_SFTP_HOST=storage.example.com
ARQ_TEST_SFTP_USER=u123
ARQ_TEST_SFTP_PORT=22

# Server-side path to the destination root (the directory that
# contains the <COMPUTER-UUID>/ subdirs, NOT the UUID itself).
ARQ_TEST_SFTP_ROOT=/home/u123/arq

# --- SFTP authentication (one of) ------------------------------
# Either set the password here ...
ARQ_TEST_SFTP_AUTH_PASSWORD=your-ssh-password-here

# ... or point at an SSH private key file. If both are set,
# password is preferred.
# ARQ_TEST_SFTP_IDENTITY=~/.ssh/id_ed25519

# --- Arq encryption password (the one Arq.app prompts for) -----
# This is the destination password, NOT the SSH password.
ARQ_TEST_DEST_PASSWORD=arq-backup-password-here
