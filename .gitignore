# Claude Code local state (per-session task lock + project-local
# settings overrides). Operator-machine-specific.
.claude/

__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/
.venv/
venv/
.coverage
htmlcov/

# Local-only credentials for the SFTP integration tests.
# See docs/COMPAT-SFTP-TESTING.md.
.env
.env.local
tests/integration/.env
# .secrets/: ignore everything except the operator-facing
# template files (README + *.example) so the layout is
# self-documenting in the repo while real credentials stay out.
.secrets/*
!.secrets/README.md
!.secrets/sftp.json.example
!.secrets/dest_password.example

# Arq compat suite run artifacts (generated fixtures + writer/reader
# destinations). Default workdir lives under the project dir so the Arq.app
# GUI can pick <repo>/arq_compat_run/fixtures; the contents are transient.
# The accumulating results live in docs/arq-compat/ and ARE tracked.
/arq_compat_run/

# Local p4-side artifacts (untracked; live alongside git only).
.p4ignore
.p4-git-sync-log
